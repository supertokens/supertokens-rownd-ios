PORT=3137

SUPERTOKENS_CONNECTION_URI=http://localhost:3567
# SUPERTOKENS_API_KEY=

APP_NAME="Rownd iOS Example"
API_DOMAIN=https://your-ngrok-domain.ngrok-free.dev
API_BASE_PATH=/auth

# Comma-separated origins allowed to call this backend from WebView/browser contexts.
ALLOWED_ORIGINS=https://staging.supertokens-rownd-hub.pages.dev,http://127.0.0.1:5173,http://localhost:5173

ROWND_APP_KEY=key_xxx
ROWND_APP_SECRET=ras_xxx
ROWND_ENABLE_DEBUG_LOGS=false
ROWND_MOBILE_DEEP_LINK_BASE_URL=rowndsupertokens://

# Use the Google Web OAuth client here.
GOOGLE_CLIENT_ID=google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=google-web-client-secret

# Use the Google iOS OAuth client here so the Hub can trigger native Google sign-in.
GOOGLE_IOS_CLIENT_ID=google-ios-client-id.apps.googleusercontent.com

# Optional. Leave empty to disable Apple in the returned app config.
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
