{
  "npm": false,
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}"
  },
  "github": {
    "release": true
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    },
    "@release-it/bumper": {
      "in": "VERSION",
      "out": [
        "README.md",
        "Sources/Rownd/framework/Version.swift",
        "VERSION"
      ]
    }
  },
  "hooks": {
    "after:bump": [
      "npx podspec-bump -w -i ${version} -p SuperTokensRownd.podspec",
      "pod lib lint SuperTokensRownd.podspec --allow-warnings"
    ],
    "after:release": "pod trunk push SuperTokensRownd.podspec --allow-warnings"
  }
}
